//@version=6
indicator("Ross EMA + VWAP", overlay=true, max_labels_count=50)

// ── Inputs ──────────────────────────────────────────────────────────────────
grpEma = "EMA"
show9   = input.bool(true,  "Show 9 EMA",   group=grpEma)
show20  = input.bool(true,  "Show 20 EMA",  group=grpEma)
show200 = input.bool(true,  "Show 200 EMA", group=grpEma)
len9    = input.int(9,      "Fast Length",   minval=1, maxval=50,  group=grpEma)
len20   = input.int(20,     "Mid Length",    minval=5, maxval=100, group=grpEma)
len200  = input.int(200,    "Slow Length",   minval=50,maxval=500, group=grpEma)

grpVwap = "VWAP"
showVwap     = input.bool(true,  "Show VWAP",         group=grpVwap)
showBands    = input.bool(true,  "Show VWAP Bands",   group=grpVwap)
bandMult1    = input.float(1.0,  "Band 1 StdDev",     minval=0.5, maxval=3, step=0.5, group=grpVwap)
bandMult2    = input.float(2.0,  "Band 2 StdDev",     minval=1,   maxval=5, step=0.5, group=grpVwap)

grpSignal = "Signals"
showCross    = input.bool(true,  "Show EMA Crossovers",     group=grpSignal)
showVwapBnc  = input.bool(true,  "Show VWAP Bounce",        group=grpSignal)
showTrend    = input.bool(true,  "Show Trend Background",   group=grpSignal)

// ── EMA ─────────────────────────────────────────────────────────────────────
ema9   = ta.ema(close, len9)
ema20  = ta.ema(close, len20)
ema200 = ta.ema(close, len200)

// Ross style: 9 EMA = momentum, 20 EMA = trend, 200 EMA = big picture
plot(show9   ? ema9   : na, title="9 EMA",   color=#00BCD4, linewidth=2)
plot(show20  ? ema20  : na, title="20 EMA",  color=#FF9800, linewidth=2)
plot(show200 ? ema200 : na, title="200 EMA", color=#9C27B0, linewidth=1)

// ── VWAP + Bands ────────────────────────────────────────────────────────────
// Daily VWAP with standard deviation bands
isNewSession = ta.change(time("D")) != 0
var float cumPV    = 0.0
var float cumVol   = 0.0
var float cumPV2   = 0.0

hlc3Val = (high + low + close) / 3

if isNewSession
    cumPV  := hlc3Val * volume
    cumVol := volume
    cumPV2 := hlc3Val * hlc3Val * volume
else
    cumPV  := cumPV + hlc3Val * volume
    cumVol := cumVol + volume
    cumPV2 := cumPV2 + hlc3Val * hlc3Val * volume

vwapVal  = cumVol > 0 ? cumPV / cumVol : hlc3Val
variance = cumVol > 0 ? cumPV2 / cumVol - vwapVal * vwapVal : 0.0
stdev    = math.sqrt(math.max(variance, 0))

upper1 = vwapVal + stdev * bandMult1
lower1 = vwapVal - stdev * bandMult1
upper2 = vwapVal + stdev * bandMult2
lower2 = vwapVal - stdev * bandMult2

vwapColor = color.new(#2196F3, 0)
plot(showVwap ? vwapVal : na, title="VWAP", color=vwapColor, linewidth=2)
plot(showBands ? upper1 : na, title="+1 SD", color=color.new(#2196F3, 60), linewidth=1)
plot(showBands ? lower1 : na, title="-1 SD", color=color.new(#2196F3, 60), linewidth=1)
plot(showBands ? upper2 : na, title="+2 SD", color=color.new(#2196F3, 80), linewidth=1, style=plot.style_circles)
plot(showBands ? lower2 : na, title="-2 SD", color=color.new(#2196F3, 80), linewidth=1, style=plot.style_circles)

// VWAP band fill
p_u1 = plot(showBands ? upper1 : na, display=display.none)
p_l1 = plot(showBands ? lower1 : na, display=display.none)
fill(p_u1, p_l1, color=color.new(#2196F3, 92), title="VWAP Zone")

// ── Signals ─────────────────────────────────────────────────────────────────

// 1. EMA Crossovers (9/20)
cross9over20  = ta.crossover(ema9, ema20)
cross9under20 = ta.crossunder(ema9, ema20)

if showCross and cross9over20
    label.new(bar_index, low, "9×20↑", style=label.style_label_up, color=#00C853, textcolor=color.white, size=size.tiny)
if showCross and cross9under20
    label.new(bar_index, high, "9×20↓", style=label.style_label_down, color=#FF1744, textcolor=color.white, size=size.tiny)

// 2. VWAP Bounce — price touches VWAP from above and bounces
vwapTouch    = low <= vwapVal and close > vwapVal and close > open
vwapBounce   = vwapTouch and close > ema9 and ema9 > ema20

if showVwapBnc and vwapBounce
    label.new(bar_index, low, "VWAP↑", style=label.style_label_up, color=#2196F3, textcolor=color.white, size=size.tiny)

// 3. Trend Background
// Ross: above all 3 EMAs + VWAP = strong bullish, below all = bearish
bullTrend = close > ema9 and close > ema20 and close > vwapVal
bearTrend = close < ema9 and close < ema20 and close < vwapVal

bgcolor(showTrend and bullTrend ? color.new(#00C853, 95) : na, title="Bull Trend")
bgcolor(showTrend and bearTrend ? color.new(#FF1744, 95) : na, title="Bear Trend")

// ── Info Panel ──────────────────────────────────────────────────────────────
aboveEma9   = close > ema9
aboveEma20  = close > ema20
aboveEma200 = close > ema200
aboveVwap   = close > vwapVal
emaStack    = ema9 > ema20 and ema20 > ema200  // perfect bullish stack

var table panel = table.new(position.bottom_left, 2, 8, bgcolor=color.new(color.black, 30), border_width=1)
if barstate.islast
    table.cell(panel, 0, 0, "── EMA ──",  text_color=color.aqua, text_size=size.small)
    table.cell(panel, 1, 0, emaStack ? "STACKED" : "—", text_color=emaStack ? color.lime : color.gray, text_size=size.small)
    table.cell(panel, 0, 1, "vs 9",       text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 1, aboveEma9 ? "ABOVE" : "BELOW", text_color=aboveEma9 ? color.lime : color.red, text_size=size.small)
    table.cell(panel, 0, 2, "vs 20",      text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 2, aboveEma20 ? "ABOVE" : "BELOW", text_color=aboveEma20 ? color.lime : color.red, text_size=size.small)
    table.cell(panel, 0, 3, "vs 200",     text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 3, aboveEma200 ? "ABOVE" : "BELOW", text_color=aboveEma200 ? color.lime : color.red, text_size=size.small)
    table.cell(panel, 0, 4, "── VWAP ──", text_color=color.aqua, text_size=size.small)
    table.cell(panel, 1, 4, "",            text_color=color.aqua, text_size=size.small)
    table.cell(panel, 0, 5, "VWAP",       text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 5, "$" + str.tostring(vwapVal, "#.##"), text_color=aboveVwap ? color.lime : color.red, text_size=size.small)
    table.cell(panel, 0, 6, "Position",   text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 6, aboveVwap ? "ABOVE" : "BELOW", text_color=aboveVwap ? color.lime : color.red, text_size=size.small)
    table.cell(panel, 0, 7, "Trend",      text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 7, bullTrend ? "BULL" : bearTrend ? "BEAR" : "MIXED", text_color=bullTrend ? color.lime : bearTrend ? color.red : color.yellow, text_size=size.small)
